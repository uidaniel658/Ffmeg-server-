{
  "name": "bds-ffmpeg-server",
  "version": "1.0.0",
  "type": "module",
  "description": "Production-ready FFmpeg processing API for BD Dubbing Studio",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node scripts/test.sh",
    "lint": "eslint . --ext .js",
    "format": "prettier --write .",
    "setup": "node scripts/setup.js",
    "ffmpeg:version": "ffmpeg -version",
    "ffmpeg:test": "node -e \"const ffmpeg=require('fluent-ffmpeg');ffmpeg.setFfmpegPath(require('ffmpeg-static'));ffmpeg().getAvailableFormats((e,f)=>console.log(e? '❌ '+e.message:'✅ FFmpeg ready, formats:',Object.keys(f).slice(0,5).join(', ')))\""
  },
  "keywords": ["ffmpeg", "video-processing", "audio-processing", "api", "bd-dubbing-studio"],
  "author": "BD Dubbing Studio",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.3",
    "cors": "^2.8.5",
    "multer": "^1.4.5-lts.1",
    "fluent-ffmpeg": "^2.1.2",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "uuid": "^9.0.1",
    "dotenv": "^16.4.5",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "winston": "^3.11.0",
    "joi": "^17.12.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
