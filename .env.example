# ═══════════════════════════════════════════════════════════
# 🔐 BDS FFmpeg Server - Environment Variables Template
# ⚠️ NEVER commit your actual .env file to version control
# ═══════════════════════════════════════════════════════════

# ── 🌐 SERVER CONFIG ───────────────────────────────────────
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# ── 🔐 SECURITY ────────────────────────────────────────────
API_SECRET_KEY=your_super_secret_api_key_min_32_chars_here
CORS_ORIGIN=http://localhost:5173,https://your-main-app.repl.co

# ── 📁 FILE HANDLING ───────────────────────────────────────
MAX_FILE_SIZE=524288000
ALLOWED_VIDEO_TYPES=mp4,webm,mov,avi,mkv
ALLOWED_AUDIO_TYPES=mp3,wav,ogg,m4a,flac
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs
FILE_CLEANUP_HOURS=24

# ── 🎬 FFmpeg OPTIONS ──────────────────────────────────────
FFMPEG_PRESET=medium
FFMPEG_CRF=23
FFMPEG_AUDIO_BITRATE=192k
FFMPEG_VIDEO_BITRATE=2500k
FFMPEG_MAX_DURATION=7200

# ── 🔄 JOB QUEUE (optional for long processes) ─────────────
ENABLE_JOB_QUEUE=false
JOB_TIMEOUT_MS=300000

# ── 📊 LOGGING ─────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE=./logs/ffmpeg-server.log
